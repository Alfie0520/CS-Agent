# 微信服务号配置
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_TOKEN=your_wechat_token
WECHAT_ENCODING_AES_KEY=        # 消息加解密用，不启用可留空

# MiniMax LLM 配置
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01   # 填写你实际开通的模型名

# 公司老板微信二维码（上传后填入 media_id，供 get_wechat_qr_code 工具使用）
# WECHAT_QR_CODE_MEDIA_ID=

# 参访图片 API 访问密钥（必填，用于保护图片管理接口）
VISIT_IMAGE_API_KEY=change-me-to-a-random-secret-string

# 可选：自定义系统提示词
# MINIMAX_SYSTEM_PROMPT=你是一个专业、耐心的客服助手...

# 对话历史 SQLite 存储路径（绝对路径，确保代码更新后数据不丢失）
# SESSION_DB_PATH=/data/sessions.db

# 多轮对话上下文保留时长（秒），默认永不过期（0）
# SESSION_TTL=0

# 服务配置
PORT=80
LOG_LEVEL=INFO

# ---- 微信客服 (KF) 渠道 ----
# 设为 true 启用客服渠道，需同时填写以下所有配置
KF_ENABLED=false
KF_CORP_ID=your_corp_id              # 企业微信 corpid
KF_SECRET=your_kf_secret             # 微信客服后台「开发配置」中的 Secret
KF_TOKEN=your_kf_token               # 回调配置的 Token
KF_ENCODING_AES_KEY=your_aes_key     # 回调配置的 EncodingAESKey（43位）
KF_OPEN_KFID=wkXXXXXX               # 客服账号 ID，在「客服账号」页面查看
